# Documents Service Configuration

# Server Configuration
PORT=3012
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=documents

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# File Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=./uploads
STORAGE_MAX_SIZE=52428800

# S3 Configuration (if using S3)
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Document Generation
PDF_GENERATOR=local
PDF_TEMPLATE_PATH=./templates

# Service Discovery
SIS_SERVICE_URL=http://localhost:3001
HR_SERVICE_URL=http://localhost:3005

# Logging
LOG_LEVEL=debug
