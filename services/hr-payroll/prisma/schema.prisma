datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id                String   @id @default(cuid())
  tenantId          String
  userId            String?
  employeeNumber    String   @unique
  firstName         String
  lastName          String
  email             String
  phone             String?
  department        String
  position          String
  hireDate          DateTime
  employmentType    String   @default("full-time")
  status            String   @default("active")
  salary            Decimal? @db.Decimal(15, 2)
  manager           String?
  terminationReason String?
  lastDay           DateTime?
  payroll           Payroll[]
  benefits          Benefit[]
  leaveRecords      LeaveRecord[]
  reviews           PerformanceReview[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
  @@index([department])
  @@index([status])
}

model Payroll {
  id          String   @id @default(cuid())
  tenantId    String
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  payPeriod   String
  payDate     DateTime
  grossPay    Decimal  @db.Decimal(15, 2)
  netPay      Decimal  @db.Decimal(15, 2)
  taxes       Decimal  @default(0) @db.Decimal(15, 2)
  socialSecurity Decimal @default(0) @db.Decimal(15, 2)
  status      String   @default("draft")
  processedBy String?
  processedAt DateTime?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@index([payPeriod])
  @@index([status])
}

model Benefit {
  id              String   @id @default(cuid())
  tenantId        String
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  benefitType     String
  enrollmentDate  DateTime
  terminationDate DateTime?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@index([benefitType])
}

model LeaveRecord {
  id              String   @id @default(cuid())
  tenantId        String
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  leaveType       String
  startDate       DateTime
  endDate         DateTime
  status          String   @default("pending")
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
}

model PerformanceReview {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  reviewDate DateTime
  rating     Decimal  @db.Decimal(3, 2)
  comments   String?
  reviewer   String
  status     String   @default("draft")
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@index([status])
}
