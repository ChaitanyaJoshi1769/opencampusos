# Content Library Service Configuration

# Server Configuration
PORT=3024
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=content_library

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# File Storage
STORAGE_TYPE=s3
S3_BUCKET=opencampusos-content
S3_REGION=us-east-1
MAX_FILE_SIZE=536870912

# Content Configuration
ENABLE_PREVIEW=true
ENABLE_TRANSCODING=true
SUPPORTED_FORMATS=pdf,docx,pptx,mp4,mp3,jpg,png,zip

# Service Discovery
SEARCH_SERVICE_URL=http://localhost:3018
AUDIT_SERVICE_URL=http://localhost:3015
NOTIFICATION_SERVICE_URL=http://localhost:3011

# Logging
LOG_LEVEL=debug
