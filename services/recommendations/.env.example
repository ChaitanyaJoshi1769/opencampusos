# Recommendations Service Configuration

# Server Configuration
PORT=3021
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=recommendations

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# ML/AI Configuration
ML_MODEL_PATH=./models
VECTOR_DB_URL=http://localhost:6333
ENABLE_PREDICTIONS=true

# Recommendation Engine
RECOMMENDATION_ALGORITHM=collaborative_filtering
MIN_CONFIDENCE_SCORE=0.65
CACHE_RECOMMENDATIONS=true

# Service Discovery
AUDIT_SERVICE_URL=http://localhost:3015
NOTIFICATION_SERVICE_URL=http://localhost:3011

# Logging
LOG_LEVEL=debug
