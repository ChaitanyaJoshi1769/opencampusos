# Student Success Service Configuration

# Server Configuration
PORT=3026
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=student_success

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Student Success Configuration
EARLY_WARNING_THRESHOLD=2.0
INTERVENTION_FOLLOWUP_DAYS=7
ALERT_ESCALATION_ENABLED=true

# Integration
PREDICTIONS_SERVICE_URL=http://localhost:3021
NOTIFICATIONS_SERVICE_URL=http://localhost:3011
EVENT_BUS_URL=http://localhost:3025

# Logging
LOG_LEVEL=debug
