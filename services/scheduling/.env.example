# Scheduling Service Configuration

# Server Configuration
PORT=3013
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=scheduling

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Service Discovery
COURSES_SERVICE_URL=http://localhost:3001
ROOMS_SERVICE_URL=http://localhost:localhost:3013

# Calendar Configuration
TIMEZONE=America/Chicago
WEEK_START_DAY=Sunday

# Notification Integration
NOTIFICATION_SERVICE_URL=http://localhost:3011

# Logging
LOG_LEVEL=debug
