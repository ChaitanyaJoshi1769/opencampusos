# Audit & Compliance Service Configuration

# Server Configuration
PORT=3015
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=audit

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Compliance Standards
ENABLED_STANDARDS=FERPA,GDPR,HIPAA,SOC2,CCPA
BREACH_NOTIFICATION_REQUIRED=true
BREACH_NOTIFICATION_EMAIL=compliance@opencampusos.edu

# Audit Configuration
AUDIT_RETENTION_DAYS=2555
LOG_SENSITIVE_DATA=false
ENCRYPTION_KEY=

# Service Discovery
NOTIFICATION_SERVICE_URL=http://localhost:3011

# Logging
LOG_LEVEL=debug
