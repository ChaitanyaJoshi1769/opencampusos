generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Recommendation {
  id          String   @id @default(cuid())
  tenantId    String
  studentId   String
  type        String
  algorithm   String
  data        Json?
  requestedAt DateTime
  generatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([studentId])
  @@index([generatedAt])
  @@map("recommendations")
}

model CourseRating {
  id        String   @id @default(cuid())
  tenantId  String
  studentId String
  courseId  String
  rating    Int
  review    String?
  ratedAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([studentId])
  @@index([courseId])
  @@map("course_ratings")
}

model Prediction {
  id              String   @id @default(cuid())
  tenantId        String
  studentId       String
  predictionType  String
  result          Json?
  confidence      Float?
  requestedAt     DateTime
  generatedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([studentId])
  @@index([predictionType])
  @@map("predictions")
}

model MLModel {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  version     String
  type        String
  accuracy    Float?
  trainedAt   DateTime?
  active      Boolean  @default(false)
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([type])
  @@map("ml_models")
}
