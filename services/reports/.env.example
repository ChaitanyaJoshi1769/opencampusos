# Reports & Export Service Configuration

# Server Configuration
PORT=3014
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=reports

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Service Discovery
SIS_SERVICE_URL=http://localhost:3001
FINANCIAL_AID_SERVICE_URL=http://localhost:3004
HR_SERVICE_URL=http://localhost:3005
NOTIFICATIONS_SERVICE_URL=http://localhost:3011

# File Storage Configuration
STORAGE_PATH=./exports
MAX_EXPORT_SIZE=52428800

# Report Templates
TEMPLATES_PATH=./templates

# Email Configuration
ENABLE_EMAIL_EXPORT=true
EMAIL_RECIPIENTS=admin@opencampusos.edu

# Logging
LOG_LEVEL=debug
