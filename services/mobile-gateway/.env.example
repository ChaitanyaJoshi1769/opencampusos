# Mobile GraphQL Gateway Configuration

# Server Configuration
PORT=3022
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=mobile_gateway

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# GraphQL Configuration
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true

# Mobile Configuration
OFFLINE_ENABLED=true
SYNC_INTERVAL=300000
MAX_OFFLINE_SIZE=104857600
CACHE_ENABLED=true

# Redis Cache
REDIS_URL=redis://localhost:6379/1

# Service URLs
SIS_SERVICE_URL=http://localhost:3001
STUDENT_PORTAL_URL=http://localhost:3004
FACULTY_PORTAL_URL=http://localhost:3005
LMS_HUB_URL=http://localhost:3010
SEARCH_SERVICE_URL=http://localhost:3018
RECOMMENDATIONS_URL=http://localhost:3021

# Logging
LOG_LEVEL=debug
