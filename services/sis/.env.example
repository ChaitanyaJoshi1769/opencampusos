# SIS Service Configuration

# Server
PORT=3002
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Database (shared from root)
DATABASE_URL=postgresql://opencampus:opencampus@localhost:5432/opencampus?schema=public

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=sis-service
KAFKA_CLIENT_ID=sis-service

# Redis
REDIS_URL=redis://localhost:6379

# Multi-tenancy
CURRENT_TENANT_ID=00000000-0000-0000-0000-000000000001

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3010

# Logging
LOG_FORMAT=json
LOG_LEVEL=info
