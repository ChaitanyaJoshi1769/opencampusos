# Integration Service Configuration

# Server Configuration
PORT=3019
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=integration

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Canvas Configuration
CANVAS_BASE_URL=https://canvas.example.com
CANVAS_API_TOKEN=

# Blackboard Configuration
BLACKBOARD_BASE_URL=https://learn.example.com
BLACKBOARD_CLIENT_ID=
BLACKBOARD_CLIENT_SECRET=

# Banner Configuration
BANNER_BASE_URL=https://banner.example.com
BANNER_USERNAME=
BANNER_PASSWORD=

# Sync Configuration
SYNC_BATCH_SIZE=100
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_DELAY=5000

# Service Discovery
AUDIT_SERVICE_URL=http://localhost:3015
NOTIFICATION_SERVICE_URL=http://localhost:3011

# Logging
LOG_LEVEL=debug
