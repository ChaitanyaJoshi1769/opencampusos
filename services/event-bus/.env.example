# Event Bus Service Configuration

# Server Configuration
PORT=3025
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=event_bus

# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=event-bus-service
KAFKA_GROUP_ID=event-bus-group

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Event Configuration
MAX_RETRIES=3
RETRY_DELAY=5000
DELIVERY_TIMEOUT=30000
BATCH_SIZE=100

# Service Discovery
AUDIT_SERVICE_URL=http://localhost:3015

# Logging
LOG_LEVEL=debug
