# Finance & Accounting Service Configuration

# Server Configuration
PORT=3030
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=finance

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Service Discovery
NOTIFICATION_SERVICE_URL=http://localhost:3011
AUDIT_SERVICE_URL=http://localhost:3015

# Logging
LOG_LEVEL=debug
