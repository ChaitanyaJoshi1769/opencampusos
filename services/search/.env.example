# Search Service Configuration

# Server Configuration
PORT=3018
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=search

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Search Configuration
DEFAULT_SEARCH_LIMIT=20
MAX_SEARCH_LIMIT=100
SUGGEST_TIMEOUT=5000

# Service Discovery
AUDIT_SERVICE_URL=http://localhost:3015
NOTIFICATION_SERVICE_URL=http://localhost:3011

# Logging
LOG_LEVEL=debug
