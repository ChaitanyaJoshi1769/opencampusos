# LMS Hub Service Configuration

# Server Configuration
PORT=3008
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=lms_hub

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Service Discovery
AUTH_SERVICE_URL=http://localhost:3001
SIS_SERVICE_URL=http://localhost:3002
ADMISSIONS_SERVICE_URL=http://localhost:3003

# GraphQL Configuration
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true

# Logging
LOG_LEVEL=debug

# Feature Flags
ENABLE_GRADING=true
ENABLE_CONTENT_MANAGEMENT=true
ENABLE_ANALYTICS=true

# Event Stream Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=lms-hub-consumer
