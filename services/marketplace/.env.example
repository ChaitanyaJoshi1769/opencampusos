# Marketplace Service Configuration

# Server Configuration
PORT=3016
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=marketplace

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Marketplace Configuration
MARKETPLACE_CURRENCY=USD
DEVELOPER_REVENUE_SHARE=0.70
PLATFORM_COMMISSION=0.30
PAYMENT_PROCESSOR=stripe

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# Plugin Configuration
MAX_PLUGIN_SIZE=52428800
ALLOWED_PLUGIN_TYPES=.js,.ts,.tar.gz

# Service Discovery
NOTIFICATION_SERVICE_URL=http://localhost:3011
AUDIT_SERVICE_URL=http://localhost:3015

# Logging
LOG_LEVEL=debug
