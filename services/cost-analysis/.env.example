# Cost Analysis Service Configuration

# Server Configuration
PORT=3023
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencampusos?schema=cost_analysis

# Multi-Tenant Configuration
CURRENT_TENANT_ID=default-tenant

# Cost Analysis Configuration
FORECAST_ALGORITHM=linear_regression
CONFIDENCE_THRESHOLD=0.80
ALERT_THRESHOLD_PERCENTAGE=90
CURRENCY=USD

# Notifications
ALERT_EMAIL_ENABLED=true
SLACK_WEBHOOK_URL=

# Service Discovery
NOTIFICATION_SERVICE_URL=http://localhost:3011
AUDIT_SERVICE_URL=http://localhost:3015

# Logging
LOG_LEVEL=debug
